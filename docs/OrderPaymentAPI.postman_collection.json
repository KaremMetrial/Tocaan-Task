{
  "info": {
    "name": "Order & Payment Management API",
    "description": "Laravel 13 modular API for orders and payments with JWT auth and a pluggable (Strategy-pattern) payment-gateway architecture.\n\nGateways: credit_card and paypal (simulated, settle instantly) and myfatoorah (real hosted/redirect integration — returns a PENDING payment + redirect_url, confirmed later via webhook).\n\nRun it as a flow (top to bottom):\n1. **Authentication > Register** (or **Login**) — JWT auto-saved to `token`.\n2. **Orders > Create Order** — new id auto-saved to `order_id`; every order/payment request below uses it.\n3. **Payments > Process Payment** — saves `transaction_reference` for the webhook.\n\nBase URL: set `base_url`. Sail serves on http://localhost (port 80); `php artisan serve` uses http://127.0.0.1:8000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "order_id", "value": "1", "type": "string" },
    { "key": "transaction_reference", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.authorization) {",
                  "  pm.collectionVariables.set('token', res.data.authorization.token);",
                  "}",
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "description": "Create a user and receive a JWT. Fields: name, email (unique), password (confirmed), password_confirmation."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {},
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful.\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"Demo User\", \"email\": \"demo@example.com\" },\n    \"authorization\": { \"token\": \"<jwt>\", \"type\": \"bearer\", \"expires_in\": 3600 }\n  }\n}"
            },
            {
              "name": "422 Validation Error",
              "originalRequest": {},
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.authorization) {",
                  "  pm.collectionVariables.set('token', res.data.authorization.token);",
                  "}",
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}" },
            "description": "Authenticate and capture the JWT. 401 on invalid credentials."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful.\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"Demo User\", \"email\": \"demo@example.com\" },\n    \"authorization\": { \"token\": \"<jwt>\", \"type\": \"bearer\", \"expires_in\": 3600 }\n  }\n}"
            },
            {
              "name": "401 Invalid Credentials",
              "originalRequest": {},
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid credentials.\"\n}"
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] },
            "description": "Return the authenticated user."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"] },
            "description": "Invalidate the current JWT."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/orders?status=confirmed&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "status", "value": "confirmed", "description": "Optional: pending | confirmed | cancelled" },
                { "key": "per_page", "value": "15", "description": "Optional, 1-100 (default 15)" },
                { "key": "customer", "value": "acme", "description": "Optional: partial match on customer_name", "disabled": true },
                { "key": "email", "value": "buyer@acme.test", "description": "Optional: partial match on customer_email", "disabled": true }
              ]
            },
            "description": "Paginated list of orders. All filters optional (OrderFilter): status, customer, email, per_page."
          },
          "response": []
        },
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('order_id', res.data.id);",
                  "}",
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_name\": \"Acme Corp\",\n  \"customer_email\": \"buyer@acme.test\",\n  \"status\": \"confirmed\",\n  \"items\": [\n    { \"product_name\": \"Widget\", \"quantity\": 2, \"price\": 10.50 },\n    { \"product_name\": \"Gadget\", \"quantity\": 1, \"price\": 5.00 }\n  ]\n}"
            },
            "description": "Create an order; total is computed server-side. `status` optional (default pending). Set 'confirmed' to make it payable. Captures the new id into order_id."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {},
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Order created successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"customer_name\": \"Acme Corp\",\n    \"customer_email\": \"buyer@acme.test\",\n    \"status\": \"confirmed\",\n    \"total\": \"26.00\",\n    \"items\": [\n      { \"id\": 1, \"product_name\": \"Widget\", \"quantity\": 2, \"price\": \"10.50\", \"line_total\": \"21.00\" },\n      { \"id\": 2, \"product_name\": \"Gadget\", \"quantity\": 1, \"price\": \"5.00\", \"line_total\": \"5.00\" }\n    ]\n  }\n}"
            },
            {
              "name": "422 Validation Error",
              "originalRequest": {},
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"customer_email\": [\"The customer email field is required.\"],\n    \"items\": [\"The items field is required.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Show Order",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["api", "orders", "{{order_id}}"] },
            "description": "Show a single order with its items and payments."
          },
          "response": []
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["api", "orders", "{{order_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\",\n  \"items\": [\n    { \"product_name\": \"Widget Pro\", \"quantity\": 3, \"price\": 12.00 }\n  ]\n}"
            },
            "description": "Update an order (PUT/PATCH). All fields optional; when items is present it fully replaces the set and the total is recalculated."
          },
          "response": []
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}", "host": ["{{base_url}}"], "path": ["api", "orders", "{{order_id}}"] },
            "description": "Delete an order. Blocked with 409 if the order has payments."
          },
          "response": [
            {
              "name": "409 Has Payments",
              "originalRequest": {},
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"This order cannot be deleted because it has associated payments.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "List All Payments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "payments"],
              "query": [
                { "key": "status", "value": "successful", "description": "Optional: pending | successful | failed", "disabled": true },
                { "key": "method", "value": "credit_card", "description": "Optional: credit_card | paypal | myfatoorah", "disabled": true },
                { "key": "order_id", "value": "{{order_id}}", "description": "Optional: filter by order", "disabled": true },
                { "key": "per_page", "value": "15", "description": "Optional (default 15)", "disabled": true }
              ]
            },
            "description": "Paginated list of all payments. Optional filters (PaymentFilter): status, method, order_id."
          },
          "response": []
        },
        {
          "name": "List Order Payments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id}}/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{order_id}}", "payments"],
              "query": [
                { "key": "status", "value": "successful", "description": "Optional: pending | successful | failed", "disabled": true },
                { "key": "method", "value": "myfatoorah", "description": "Optional: credit_card | paypal | myfatoorah", "disabled": true }
              ]
            },
            "description": "Payments belonging to a single order."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Order payments retrieved successfully.\",\n  \"data\": [\n    {\n      \"id\": 1,\n      \"order_id\": 1,\n      \"method\": \"credit_card\",\n      \"status\": \"successful\",\n      \"amount\": \"26.00\",\n      \"transaction_reference\": \"CC-8C39CB968AC1\",\n      \"created_at\": \"2026-06-28T19:00:00+00:00\"\n    }\n  ],\n  \"meta\": { \"current_page\": 1, \"per_page\": 15, \"total\": 1, \"last_page\": 1 }\n}"
            }
          ]
        },
        {
          "name": "Process Payment (credit_card)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.transaction_reference) {",
                  "  pm.collectionVariables.set('transaction_reference', res.data.transaction_reference);",
                  "}",
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}/payments", "host": ["{{base_url}}"], "path": ["api", "orders", "{{order_id}}", "payments"] },
            "body": { "mode": "raw", "raw": "{\n  \"method\": \"credit_card\"\n}" },
            "description": "Process a payment. `method`: credit_card | paypal | myfatoorah. Only a CONFIRMED order is payable (else 409). Unknown method -> 422. Captures transaction_reference for the webhook."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {},
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Payment processed successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"order_id\": 1,\n    \"method\": \"credit_card\",\n    \"status\": \"successful\",\n    \"amount\": \"26.00\",\n    \"transaction_reference\": \"CC-8C39CB968AC1\"\n  }\n}"
            },
            {
              "name": "409 Order Not Confirmed",
              "originalRequest": {},
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Payments can only be processed for confirmed orders. This order is 'pending'.\"\n}"
            },
            {
              "name": "422 Unsupported Gateway",
              "originalRequest": {},
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Unsupported payment gateway: [bitcoin].\",\n  \"errors\": {\n    \"method\": [\"The payment method 'bitcoin' is not supported.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Process Payment (MyFatoorah)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.transaction_reference) {",
                  "  pm.collectionVariables.set('transaction_reference', res.data.transaction_reference);",
                  "}",
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('is pending with redirect_url', function () {",
                  "  pm.expect(res.data.status).to.eql('pending');",
                  "  pm.expect(res.data).to.have.property('redirect_url');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/{{order_id}}/payments", "host": ["{{base_url}}"], "path": ["api", "orders", "{{order_id}}", "payments"] },
            "body": { "mode": "raw", "raw": "{\n  \"method\": \"myfatoorah\"\n}" },
            "description": "Initiate a MyFatoorah (hosted/redirect) payment. Returns a PENDING payment with `redirect_url` — send the customer there. The final status arrives via the MyFatoorah webhook (Gateway Webhook below). Requires MYFATOORAH_API_KEY configured."
          },
          "response": [
            {
              "name": "201 Pending (redirect)",
              "originalRequest": {},
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Payment processed successfully.\",\n  \"data\": {\n    \"id\": 2,\n    \"order_id\": 1,\n    \"method\": \"myfatoorah\",\n    \"status\": \"pending\",\n    \"amount\": \"26.00\",\n    \"transaction_reference\": \"123456\",\n    \"redirect_url\": \"https://apitest.myfatoorah.com/KW/ie/abc123\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Gateway Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Webhook-Signature", "value": "", "description": "Required only when the gateway has a webhook_secret configured; must equal that secret.", "disabled": true }
            ],
            "url": { "raw": "{{base_url}}/api/payments/webhook/credit_card", "host": ["{{base_url}}"], "path": ["api", "payments", "webhook", "credit_card"] },
            "body": { "mode": "raw", "raw": "{\n  \"reference\": \"{{transaction_reference}}\",\n  \"status\": \"failed\"\n}" },
            "description": "Asynchronous gateway callback — UNAUTHENTICATED (no Bearer token). Path segment is the gateway key (credit_card | paypal | myfatoorah).\n\n- credit_card / paypal: body is { reference, status } (status: pending | successful | failed).\n- myfatoorah: body is { Data: { InvoiceId } }; the status is fetched server-side from MyFatoorah, not trusted from the body.\n\nReturns 422 for an unknown gateway, 404 for an unknown reference, 401 for an invalid signature."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Webhook processed successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"order_id\": 1,\n    \"method\": \"credit_card\",\n    \"status\": \"failed\",\n    \"amount\": \"26.00\",\n    \"transaction_reference\": \"CC-8C39CB968AC1\"\n  }\n}"
            },
            {
              "name": "404 Unknown Reference",
              "originalRequest": {},
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"No payment found for reference [CC-DOESNOTEXIST].\"\n}"
            },
            {
              "name": "422 Unknown Gateway",
              "originalRequest": {},
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Unsupported payment gateway: [bitcoin].\",\n  \"errors\": {\n    \"method\": [\"The payment method 'bitcoin' is not supported.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "MyFatoorah Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/payments/webhook/myfatoorah", "host": ["{{base_url}}"], "path": ["api", "payments", "webhook", "myfatoorah"] },
            "body": { "mode": "raw", "raw": "{\n  \"Data\": {\n    \"InvoiceId\": \"{{transaction_reference}}\"\n  }\n}" },
            "description": "MyFatoorah callback. The API looks up the authoritative status via /v2/getPaymentStatus for the InvoiceId and updates the matching payment (Paid -> successful, Failed/Expired -> failed)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {},
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"Webhook processed successfully.\",\n  \"data\": {\n    \"id\": 2,\n    \"order_id\": 1,\n    \"method\": \"myfatoorah\",\n    \"status\": \"successful\",\n    \"amount\": \"26.00\",\n    \"transaction_reference\": \"123456\"\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
